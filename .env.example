# ============================================================
# 古代水利工程遗迹系统 - 环境变量配置
# 复制此文件为 .env 后修改
# ============================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=water_heritage
POSTGRES_PASSWORD=Heritage@2024!
POSTGRES_DB=water_heritage

# ---------- Redis ----------
REDIS_PASSWORD=Redis@2024!

# ---------- 数据模拟器 ----------
# 生成遗迹数量
SIMULATOR_SITES=300
# 朝代过滤: all | 唐 | 宋 | 明 ...
SIMULATOR_DYNASTY=all
# 类型过滤: all | 渠,堰,陂,塘,井
SIMULATOR_SITE_TYPE=all
# 随机种子
SIMULATOR_SEED=42

# ---------- MQTT ----------
# (可选) 生产环境修改为MQTT用户名密码认证
